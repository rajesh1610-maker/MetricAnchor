# MetricAnchor API — environment variable reference
# Copy to .env and fill in your values.

# ── LLM ───────────────────────────────────────────────────────────────────────
# Set LLM_API_KEY to enable AI-quality parsing and answers.
# Leave empty (or set to "test-key") for stub mode — fully functional, no LLM.

LLM_PROVIDER=openai           # openai | anthropic | openai_compatible
LLM_API_KEY=                  # sk-... for OpenAI, or your Anthropic key
LLM_MODEL=gpt-4o              # gpt-4o | claude-opus-4-6 | your local model
LLM_BASE_URL=                 # Only for openai_compatible (e.g. http://localhost:11434/v1)
LLM_MAX_TOKENS=2048

# ── Storage ───────────────────────────────────────────────────────────────────
DATA_DIR=./data
DATABASE_URL=sqlite+aiosqlite:///./data/metricanchor.db
MAX_UPLOAD_BYTES=524288000    # 500 MB

# ── API ───────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000
API_DEBUG=true

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO                # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=human              # human (coloured terminal) | json (structured, for prod)
