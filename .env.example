# ── LLM Provider ─────────────────────────────────────────────────────────────
# Options: openai | anthropic | openai_compatible
LLM_PROVIDER=openai

# Your API key for the chosen provider.
# For openai_compatible local models (e.g. Ollama), set to any non-empty string.
LLM_API_KEY=sk-...

# Model name to use for SQL generation and Q&A.
# OpenAI:    gpt-4o | gpt-4o-mini | gpt-3.5-turbo
# Anthropic: claude-3-5-sonnet-20241022 | claude-3-haiku-20240307
# Ollama:    llama3.2 | mistral | codellama
LLM_MODEL=gpt-4o

# Base URL — only required for openai_compatible local models.
# Example (Ollama): http://localhost:11434/v1
# Leave blank for OpenAI or Anthropic.
LLM_BASE_URL=

# Maximum tokens to request per LLM call.
LLM_MAX_TOKENS=2048

# Whether to include sample row values in the LLM prompt for schema context.
# Set to false to keep raw data off the wire entirely.
LLM_SEND_SAMPLE_ROWS=true

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite connection string for app metadata (datasets, questions, feedback).
DATABASE_URL=sqlite:///./data/metricanchor.db

# ── Storage ───────────────────────────────────────────────────────────────────
# Directory where uploaded files are stored.
# Must be writable by the API process. Mounted as a Docker volume by default.
DATA_DIR=./data

# Maximum upload file size in bytes. Default: 524288000 (500 MB).
MAX_UPLOAD_BYTES=524288000

# ── API ───────────────────────────────────────────────────────────────────────
# Origins allowed to call the API from the browser.
# Comma-separated. In production, replace with your actual frontend URL.
CORS_ORIGINS=http://localhost:3000

# Set to false in production.
API_DEBUG=true

# ── Frontend ──────────────────────────────────────────────────────────────────
# The URL the Next.js frontend uses to reach the API.
# In Docker, the browser calls this directly — use localhost, not the service name.
NEXT_PUBLIC_API_URL=http://localhost:8000
